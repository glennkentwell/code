{
  "manifest_version": 3,
  "name": "prompt api tester thingy",
  "description": "does the prompt api work/",
  "version": "1.0",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_title": "Toggle Prompt API Tester"
  },
  "background": {
    "service_worker": "background.js"
  },
  "sandbox": {
    "pages": ["sandbox.html"]
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
